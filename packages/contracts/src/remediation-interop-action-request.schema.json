{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/remediation-interop-action-request.schema.json",
  "title": "Remediation Interop Action Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "kind", "requestId", "remediationId", "action", "requestedAt", "requestedBy", "rendezvousManifestPath", "rendezvousBaseSha", "releaseReady", "idempotencyKey", "payload", "state", "retries"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "kind": { "type": "string", "const": "remediation-interop-action-request" },
    "requestId": { "type": "string", "minLength": 1 },
    "remediationId": { "type": "string", "minLength": 1 },
    "action": { "$ref": "#/$defs/actionKind" },
    "requestedAt": { "type": "string", "format": "date-time" },
    "requestedBy": { "type": "string", "const": "playbook" },
    "rendezvousManifestPath": { "type": "string", "minLength": 1 },
    "rendezvousBaseSha": { "type": "string", "minLength": 1 },
    "releaseReady": { "type": "boolean", "const": true },
    "idempotencyKey": { "type": "string", "minLength": 1 },
    "payload": { "type": "object" },
    "state": { "$ref": "#/$defs/executionState" },
    "blockedReason": { "$ref": "./remediation-interop-blocked-reason.schema.json" },
    "retries": { "type": "integer", "minimum": 0 }
  },
  "$defs": {
    "actionKind": {
      "type": "string",
      "enum": ["test-triage", "test-fix-plan", "apply-result", "test-autofix", "remediation-status"]
    },
    "executionState": {
      "type": "string",
      "enum": ["pending", "running", "failed", "completed", "blocked", "rejected"]
    }
  }
}
