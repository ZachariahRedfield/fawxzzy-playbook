{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.dev/schemas/pattern-portability.schema.json",
  "title": "Pattern Portability Contract",
  "description": "Deterministic cross-repository evidence contract for portable pattern transfer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "generatedAt",
    "patterns"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "kind": {
      "type": "string",
      "const": "pattern-portability"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "patterns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/patternPortabilityEntry"
      }
    }
  },
  "$defs": {
    "patternPortabilityEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pattern_id",
        "source_repo",
        "evidence_runs",
        "portability_score",
        "confidence_score",
        "supporting_artifacts",
        "related_subsystems"
      ],
      "properties": {
        "pattern_id": {
          "type": "string",
          "minLength": 1
        },
        "source_repo": {
          "type": "string",
          "minLength": 1
        },
        "evidence_runs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        },
        "portability_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidence_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "supporting_artifacts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "related_subsystems": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    }
  }
}
