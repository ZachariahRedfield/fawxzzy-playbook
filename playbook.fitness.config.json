{
  "version": 1,
  "pilot": {
    "name": "fawxzzy-fitness-bounded-pilot",
    "repository": "Fawxzzy Fitness",
    "reasoningLoop": [
      "observe",
      "represent",
      "relate",
      "compress",
      "decide"
    ],
    "artifactRoots": [
      ".playbook/run-cycles/",
      ".playbook/zettels/",
      ".playbook/graph/",
      ".playbook/groups/",
      ".playbook/pattern-cards/drafts/",
      ".playbook/promotion/",
      ".playbook/meta/",
      ".playbook/evidence/"
    ],
    "zettelExtractionTargets": [
      "component structure",
      "API routes",
      "database models",
      "UI layout patterns",
      "workout progression logic"
    ]
  },
  "advisoryMode": {
    "enabled": true,
    "automaticContractMutation": false,
    "automaticCodeEdits": false,
    "ciEnforcement": false
  },
  "metaPlaybook": {
    "enabled": true,
    "findings": [
      "duplication",
      "architecture drift",
      "pattern reuse"
    ]
  },
  "fitnessContractSource": {
    "sourceRepo": "ZachariahRedfield/fawxzzy-fitness",
    "sourceRef": "main",
    "sourcePath": "../fawxzzy-fitness/src/lib/ecosystem/fitness-integration-contract.ts",
    "syncMode": "mirrored"
  },
  "documentationUpdates": {
    "rule": "External app contracts are consumed, not semantically redesigned.",
    "pattern": "Source contract -> validated mirror -> adapter.",
    "failureMode": "Local reinterpretation drifts names/types from the source contract and breaks interoperability."
  }
}
